<Window x:Class="Clipton.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clipton"
        Width="980"
        Height="640"
        MinWidth="760"
        MinHeight="520"
        Icon="Assets/Clipton.ico"
        Background="{DynamicResource PageBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBrush" Color="#F4F6F8" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#FAFBFC" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="InputBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D8DEE6" />
        <SolidColorBrush x:Key="BorderBrushStrong" Color="#C3CAD4" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#17212B" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#667085" />
        <SolidColorBrush x:Key="AccentBrush" Color="#005FB8" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#EAF3FF" />
        <SolidColorBrush x:Key="AccentTextBrush" Color="#003E73" />

        <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Margin" Value="8,2" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="SettingTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SettingDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,3,16,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="ComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ComboBoxItemStyle}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Chrome"
                                                Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}}"
                                                CornerRadius="5"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Grid Background="{TemplateBinding Background}">
                                    <ContentPresenter Margin="10,0,32,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      RecognizesAccessKey="True"
                                                      TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
                                    <Path Width="8"
                                          Height="5"
                                          Margin="0,0,11,0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 8 0 L 4 5 Z"
                                          Fill="{DynamicResource TextSecondaryBrush}" />
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,4,0,0"
                                        Background="{DynamicResource InputBrush}"
                                        BorderBrush="{DynamicResource BorderBrushStrong}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="18,18,18,12">
                    <TextBlock x:Name="TitleText"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="Clipton" />
                    <TextBlock x:Name="HotkeyText"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>

                <ListBox x:Name="NavList"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectionChanged="NavList_OnSelectionChanged">
                    <ListBoxItem x:Name="GeneralNavItem" Style="{StaticResource NavItemStyle}" />
                    <ListBoxItem x:Name="HistoryNavItem" Style="{StaticResource NavItemStyle}" />
                    <ListBoxItem x:Name="SnippetNavItem" Style="{StaticResource NavItemStyle}" />
                </ListBox>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="28">
                <StackPanel x:Name="GeneralPage">
                    <TextBlock x:Name="GeneralHeaderText"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock x:Name="GeneralDescriptionText"
                               Margin="0,4,0,20"
                               Foreground="{DynamicResource TextSecondaryBrush}" />

                    <Border Style="{StaticResource SectionBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="HotkeyTitleText" Style="{StaticResource SettingTitleStyle}" />
                                <TextBlock x:Name="HotkeyDescriptionText" Style="{StaticResource SettingDescriptionStyle}" />
                            </StackPanel>
                            <TextBox x:Name="HotkeyBox"
                                     Grid.Column="1"
                                     VerticalContentAlignment="Center"
                                     LostFocus="HotkeyBox_OnLostFocus" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SectionBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="ThemeTitleText" Style="{StaticResource SettingTitleStyle}" />
                                <TextBlock x:Name="ThemeDescriptionText" Style="{StaticResource SettingDescriptionStyle}" />
                            </StackPanel>
                            <ComboBox x:Name="ThemeBox"
                                      Grid.Column="1"
                                      SelectionChanged="ThemeBox_OnSelectionChanged">
                                <ComboBoxItem Tag="light" />
                                <ComboBoxItem Tag="dark" />
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SectionBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="LanguageTitleText" Style="{StaticResource SettingTitleStyle}" />
                                <TextBlock x:Name="LanguageDescriptionText" Style="{StaticResource SettingDescriptionStyle}" />
                            </StackPanel>
                            <ComboBox x:Name="LocaleBox"
                                      Grid.Column="1"
                                      SelectionChanged="LocaleBox_OnSelectionChanged">
                                <ComboBoxItem Content="Use system setting" Tag="system" />
                                <ComboBoxItem Content="English" Tag="en" />
                                <ComboBoxItem Content="Japanese" Tag="ja" />
                                <ComboBoxItem Content="German" Tag="de" />
                                <ComboBoxItem Content="Spanish" Tag="es" />
                                <ComboBoxItem Content="French" Tag="fr" />
                                <ComboBoxItem Content="Korean" Tag="ko" />
                                <ComboBoxItem Content="Chinese (Simplified)" Tag="zh-Hans" />
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SectionBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="StartupTitleText" Style="{StaticResource SettingTitleStyle}" />
                                <TextBlock x:Name="StartupDescriptionText" Style="{StaticResource SettingDescriptionStyle}" />
                            </StackPanel>
                            <CheckBox x:Name="StartupCheckBox"
                                      Grid.Column="1"
                                      VerticalAlignment="Center"
                                      Checked="StartupCheckBox_OnChanged"
                                      Unchecked="StartupCheckBox_OnChanged" />
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="HistoryPage" Visibility="Collapsed">
                    <TextBlock x:Name="HistoryHeaderText"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock x:Name="HistoryDescriptionText"
                               Margin="0,4,0,20"
                               Foreground="{DynamicResource TextSecondaryBrush}" />

                    <Border Style="{StaticResource SectionBorderStyle}">
                        <StackPanel>
                            <CheckBox x:Name="PauseCaptureCheckBox"
                                      Checked="PauseCaptureCheckBox_OnChanged"
                                      Unchecked="PauseCaptureCheckBox_OnChanged" />
                            <CheckBox x:Name="PersistHistoryCheckBox"
                                      Margin="0,12,0,0"
                                      Checked="PersistHistoryCheckBox_OnChanged"
                                      Unchecked="PersistHistoryCheckBox_OnChanged" />
                            <CheckBox x:Name="MaskSensitiveContentCheckBox"
                                      Margin="0,12,0,0"
                                      Checked="MaskSensitiveContentCheckBox_OnChanged"
                                      Unchecked="MaskSensitiveContentCheckBox_OnChanged" />
                            <CheckBox x:Name="FolderModeCheckBox"
                                      Margin="0,12,0,0"
                                      Checked="FolderModeCheckBox_OnChanged"
                                      Unchecked="FolderModeCheckBox_OnChanged" />
                            <CheckBox x:Name="SimpleContextMenuCheckBox"
                                      Margin="0,12,0,0"
                                      Checked="SimpleContextMenuCheckBox_OnChanged"
                                      Unchecked="SimpleContextMenuCheckBox_OnChanged" />
                            <StackPanel Margin="0,16,0,0"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left">
                                <Button x:Name="RegisterFromHistoryButton"
                                        Click="RegisterFromHistoryButton_OnClick" />
                                <Button x:Name="ClearButton"
                                        Margin="8,0,0,0"
                                        Click="ClearButton_OnClick" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <ListBox x:Name="HistoryList"
                             MinHeight="300"
                             MouseDoubleClick="HistoryList_OnMouseDoubleClick"
                             KeyDown="HistoryList_OnKeyDown">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="8,7">
                                    <TextBlock Text="{Binding Preview}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                    <TextBlock Text="{Binding FormatSummary}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <StackPanel x:Name="SnippetPage" Visibility="Collapsed">
                    <TextBlock x:Name="SnippetHeaderText"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock x:Name="SnippetDescriptionText"
                               Margin="0,4,0,20"
                               Foreground="{DynamicResource TextSecondaryBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ListBox x:Name="SnippetList"
                                 MinHeight="360"
                                 MouseDoubleClick="SnippetList_OnMouseDoubleClick"
                                 SelectionChanged="SnippetList_OnSelectionChanged" />
                        <Border Grid.Column="2" Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock x:Name="SnippetFolderTitleText" Style="{StaticResource SettingTitleStyle}" />
                                <TextBox x:Name="SnippetFolderBox"
                                         Margin="0,8,0,14"
                                         VerticalContentAlignment="Center" />
                                <TextBlock x:Name="SnippetNameTitleText" Style="{StaticResource SettingTitleStyle}" />
                                <TextBox x:Name="SnippetNameBox"
                                         Margin="0,8,0,14"
                                         VerticalContentAlignment="Center" />
                                <TextBlock x:Name="SnippetTextTitleText" Style="{StaticResource SettingTitleStyle}" />
                                <TextBox x:Name="SnippetTextBox"
                                         Margin="0,8,0,16"
                                         MinHeight="96"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="SaveSnippetButton"
                                            Click="SaveSnippetButton_OnClick" />
                                    <Button x:Name="DeleteSnippetButton"
                                            Margin="8,0,0,0"
                                            Click="DeleteSnippetButton_OnClick" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
