<Window x:Class="Clipton.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clipton"
        Width="980"
        Height="640"
        MinWidth="760"
        MinHeight="520"
        Background="#F3F3F3"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DADADA" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1A1A" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5F6368" />
        <SolidColorBrush x:Key="AccentBrush" Color="#005FB8" />

        <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Margin" Value="6,2" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E7F1FB" />
                    <Setter Property="Foreground" Value="#003E73" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="SettingTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SettingDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,3,16,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#1A1A1A" />
            <Setter Property="BorderBrush" Value="#B8B8B8" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#B8B8B8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="#DADADA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#F9F9F9"
                BorderBrush="#DADADA"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="18,18,18,12">
                    <TextBlock x:Name="TitleText"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Text="Clipton" />
                    <TextBlock x:Name="HotkeyText"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <ListBox x:Name="NavList"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectionChanged="NavList_OnSelectionChanged">
                    <ListBoxItem x:Name="GeneralNavItem" Style="{StaticResource NavItemStyle}" />
                    <ListBoxItem x:Name="HistoryNavItem" Style="{StaticResource NavItemStyle}" />
                    <ListBoxItem x:Name="SnippetNavItem" Style="{StaticResource NavItemStyle}" />
                </ListBox>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="28">
                <StackPanel x:Name="GeneralPage">
                    <TextBlock x:Name="GeneralHeaderText"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="GeneralDescriptionText"
                               Margin="0,4,0,20"
                               Foreground="{StaticResource TextSecondaryBrush}" />

                    <Border Style="{StaticResource SectionBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="HotkeyTitleText" Style="{StaticResource SettingTitleStyle}" />
                                <TextBlock x:Name="HotkeyDescriptionText" Style="{StaticResource SettingDescriptionStyle}" />
                            </StackPanel>
                            <TextBox x:Name="HotkeyBox"
                                     Grid.Column="1"
                                     VerticalContentAlignment="Center"
                                     LostFocus="HotkeyBox_OnLostFocus" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SectionBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="LanguageTitleText" Style="{StaticResource SettingTitleStyle}" />
                                <TextBlock x:Name="LanguageDescriptionText" Style="{StaticResource SettingDescriptionStyle}" />
                            </StackPanel>
                            <ComboBox x:Name="LocaleBox"
                                      Grid.Column="1"
                                      SelectionChanged="LocaleBox_OnSelectionChanged">
                                <ComboBoxItem Content="English" Tag="en" />
                                <ComboBoxItem Content="Japanese" Tag="ja" />
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SectionBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="StartupTitleText" Style="{StaticResource SettingTitleStyle}" />
                                <TextBlock x:Name="StartupDescriptionText" Style="{StaticResource SettingDescriptionStyle}" />
                            </StackPanel>
                            <CheckBox x:Name="StartupCheckBox"
                                      Grid.Column="1"
                                      VerticalAlignment="Center"
                                      Checked="StartupCheckBox_OnChanged"
                                      Unchecked="StartupCheckBox_OnChanged" />
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="HistoryPage" Visibility="Collapsed">
                    <TextBlock x:Name="HistoryHeaderText"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="HistoryDescriptionText"
                               Margin="0,4,0,20"
                               Foreground="{StaticResource TextSecondaryBrush}" />

                    <Border Style="{StaticResource SectionBorderStyle}">
                        <StackPanel>
                            <CheckBox x:Name="PauseCaptureCheckBox"
                                      Checked="PauseCaptureCheckBox_OnChanged"
                                      Unchecked="PauseCaptureCheckBox_OnChanged" />
                            <CheckBox x:Name="PersistHistoryCheckBox"
                                      Margin="0,12,0,0"
                                      Checked="PersistHistoryCheckBox_OnChanged"
                                      Unchecked="PersistHistoryCheckBox_OnChanged" />
                            <Button x:Name="ClearButton"
                                    Margin="0,16,0,0"
                                    HorizontalAlignment="Left"
                                    Click="ClearButton_OnClick" />
                        </StackPanel>
                    </Border>

                    <ListBox x:Name="HistoryList"
                             MinHeight="300"
                             MouseDoubleClick="HistoryList_OnMouseDoubleClick"
                             KeyDown="HistoryList_OnKeyDown">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="8,7">
                                    <TextBlock Text="{Binding Preview}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                    <TextBlock Text="{Binding FormatSummary}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <StackPanel x:Name="SnippetPage" Visibility="Collapsed">
                    <TextBlock x:Name="SnippetHeaderText"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="SnippetDescriptionText"
                               Margin="0,4,0,20"
                               Foreground="{StaticResource TextSecondaryBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ListBox x:Name="SnippetList"
                                 MinHeight="360"
                                 MouseDoubleClick="SnippetList_OnMouseDoubleClick"
                                 SelectionChanged="SnippetList_OnSelectionChanged" />
                        <Border Grid.Column="2" Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock x:Name="SnippetNameTitleText" Style="{StaticResource SettingTitleStyle}" />
                                <TextBox x:Name="SnippetNameBox"
                                         Margin="0,8,0,14"
                                         VerticalContentAlignment="Center" />
                                <TextBlock x:Name="SnippetTextTitleText" Style="{StaticResource SettingTitleStyle}" />
                                <TextBox x:Name="SnippetTextBox"
                                         Margin="0,8,0,16"
                                         MinHeight="96"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="SaveSnippetButton"
                                            Click="SaveSnippetButton_OnClick" />
                                    <Button x:Name="DeleteSnippetButton"
                                            Margin="8,0,0,0"
                                            Click="DeleteSnippetButton_OnClick" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
