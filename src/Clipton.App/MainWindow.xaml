<Window x:Class="Clipton.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clipton"
        Width="860"
        Height="560"
        MinWidth="640"
        MinHeight="440"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock x:Name="TitleText"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Text="Clipton" />
            <TextBlock x:Name="HotkeyText"
                       Margin="0,4,0,0"
                       Foreground="#555" />
        </StackPanel>

        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="StartupCheckBox"
                          VerticalAlignment="Center"
                          Checked="StartupCheckBox_OnChanged"
                          Unchecked="StartupCheckBox_OnChanged" />
                <CheckBox x:Name="PauseCaptureCheckBox"
                          Margin="16,0,0,0"
                          VerticalAlignment="Center"
                          Checked="PauseCaptureCheckBox_OnChanged"
                          Unchecked="PauseCaptureCheckBox_OnChanged" />
                <CheckBox x:Name="PersistHistoryCheckBox"
                          Margin="16,0,0,0"
                          VerticalAlignment="Center"
                          Checked="PersistHistoryCheckBox_OnChanged"
                          Unchecked="PersistHistoryCheckBox_OnChanged" />
                <TextBox x:Name="HotkeyBox"
                         Width="140"
                         Margin="16,0,0,0"
                         VerticalContentAlignment="Center"
                         LostFocus="HotkeyBox_OnLostFocus" />
                <ComboBox x:Name="LocaleBox"
                          Width="96"
                          Margin="8,0,0,0"
                          SelectionChanged="LocaleBox_OnSelectionChanged">
                    <ComboBoxItem Content="English" Tag="en" />
                    <ComboBoxItem Content="Japanese" Tag="ja" />
                </ComboBox>
            </StackPanel>

            <Button x:Name="ClearButton"
                    Grid.Column="1"
                    Padding="14,7"
                    Click="ClearButton_OnClick" />
        </Grid>

        <TabControl>
            <TabItem x:Name="HistoryTab">
                <ListBox x:Name="HistoryList"
                         MouseDoubleClick="HistoryList_OnMouseDoubleClick"
                         KeyDown="HistoryList_OnKeyDown">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,6">
                                <TextBlock Text="{Binding Preview}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding FormatSummary}"
                                           Foreground="#666"
                                           FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem x:Name="SnippetTab">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ListBox x:Name="SnippetList"
                             MouseDoubleClick="SnippetList_OnMouseDoubleClick"
                             SelectionChanged="SnippetList_OnSelectionChanged" />
                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SnippetNameBox"
                                 VerticalContentAlignment="Center" />
                        <TextBox x:Name="SnippetTextBox"
                                 Grid.Column="1"
                                 Margin="8,0,0,0"
                                 VerticalContentAlignment="Center" />
                        <Button x:Name="SaveSnippetButton"
                                Grid.Column="2"
                                Margin="8,0,0,0"
                                Padding="14,7"
                                Click="SaveSnippetButton_OnClick" />
                        <Button x:Name="DeleteSnippetButton"
                                Grid.Column="3"
                                Margin="8,0,0,0"
                                Padding="14,7"
                                Click="DeleteSnippetButton_OnClick" />
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
