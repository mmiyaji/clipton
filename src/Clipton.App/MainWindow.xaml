<Window x:Class="Clipton.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clipton"
        Width="760"
        Height="520"
        MinWidth="520"
        MinHeight="420"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock x:Name="TitleText"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Text="Clipton" />
            <TextBlock x:Name="HotkeyText"
                       Margin="0,4,0,0"
                       Foreground="#555" />
        </StackPanel>

        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="StartupCheckBox"
                          VerticalAlignment="Center"
                          Checked="StartupCheckBox_OnChanged"
                          Unchecked="StartupCheckBox_OnChanged" />
                <TextBox x:Name="HotkeyBox"
                         Width="140"
                         Margin="16,0,0,0"
                         VerticalContentAlignment="Center"
                         LostFocus="HotkeyBox_OnLostFocus" />
                <ComboBox x:Name="LocaleBox"
                          Width="96"
                          Margin="8,0,0,0"
                          SelectionChanged="LocaleBox_OnSelectionChanged">
                    <ComboBoxItem Content="English" Tag="en" />
                    <ComboBoxItem Content="日本語" Tag="ja" />
                </ComboBox>
            </StackPanel>

            <Button x:Name="ClearButton"
                    Grid.Column="1"
                    Padding="14,7"
                    Click="ClearButton_OnClick" />
        </Grid>

        <TabControl>
            <TabItem x:Name="HistoryTab">
                <ListBox x:Name="HistoryList"
                         MouseDoubleClick="HistoryList_OnMouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,6">
                                <TextBlock Text="{Binding Preview}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding FormatSummary}"
                                           Foreground="#666"
                                           FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem x:Name="SnippetTab">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ListBox x:Name="SnippetList"
                             MouseDoubleClick="SnippetList_OnMouseDoubleClick" />
                    <TextBlock Grid.Row="1"
                               Margin="0,10,0,0"
                               Foreground="#666"
                               Text="Snippets are stored in snippets.json. Edit the file and restart Clipton for now." />
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
