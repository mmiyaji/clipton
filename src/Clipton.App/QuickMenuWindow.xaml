<Window x:Class="Clipton.App.QuickMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="390"
        SizeToContent="Height"
        MaxHeight="560"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="True"
        Topmost="True"
        Background="Transparent"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        Deactivated="Window_OnDeactivated">
    <Border Background="#F9FAFB"
            BorderBrush="#9AA5B1"
            BorderThickness="1"
            CornerRadius="4"
            Padding="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="2"
                              Opacity="0.22" />
        </Border.Effect>
        <DockPanel>
            <Grid DockPanel.Dock="Top" Margin="6,3,6,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TitleText"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#1F2933" />
                <TextBlock Grid.Column="1"
                           FontSize="11"
                           Foreground="#6B7280"
                           Text="Enter: Paste  T: Text  Esc" />
            </Grid>

            <ListBox x:Name="ItemsList"
                     MinHeight="80"
                     MaxHeight="480"
                     BorderThickness="0"
                     Background="Transparent"
                     KeyboardNavigation.TabNavigation="Cycle"
                     KeyDown="ItemsList_OnKeyDown"
                     PreviewMouseLeftButtonUp="ItemsList_OnPreviewMouseLeftButtonUp">
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,1" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DDEBFA" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8,5" CornerRadius="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="22"
                                        Height="22"
                                        Margin="0,0,8,0"
                                        Background="{Binding AccentBrush}"
                                        CornerRadius="3">
                                    <TextBlock Text="{Binding KindLabel}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="White" />
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="12"
                                               Foreground="#111827"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Subtitle}"
                                               Margin="0,1,0,0"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="#52606D"
                                           Text="{Binding CommandHint}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
