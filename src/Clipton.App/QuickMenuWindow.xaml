<Window x:Class="Clipton.App.QuickMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="386"
        SizeToContent="Height"
        MaxHeight="560"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="True"
        Topmost="True"
        Background="Transparent"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        Deactivated="Window_OnDeactivated">
    <Window.Resources>
        <SolidColorBrush x:Key="QuickPanelBrush" Color="#F9FAFB" />
        <SolidColorBrush x:Key="QuickBorderBrush" Color="#9AA5B1" />
        <SolidColorBrush x:Key="QuickTextBrush" Color="#111827" />
        <SolidColorBrush x:Key="QuickSecondaryTextBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="QuickSelectionBrush" Color="#DDEBFA" />
        <SolidColorBrush x:Key="QuickItemBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="QuickItemBorderBrush" Color="#E3E8EF" />
        <SolidColorBrush x:Key="QuickFocusBorderBrush" Color="#6AA7E8" />
        <SolidColorBrush x:Key="QuickPreviewBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="QuickPreviewBorderBrush" Color="#CAD3DD" />
        <SolidColorBrush x:Key="QuickFolderBrush" Color="#EEF5FF" />
        <SolidColorBrush x:Key="QuickFolderRowBrush" Color="#F3F8FF" />
        <SolidColorBrush x:Key="QuickFolderBorderBrush" Color="#BCD7F6" />
        <SolidColorBrush x:Key="QuickFolderTextBrush" Color="#174A7C" />
        <SolidColorBrush x:Key="QuickSeparatorBrush" Color="#3A3A3A" />
    </Window.Resources>
    <Border x:Name="RootBorder"
            Background="{DynamicResource QuickPanelBrush}"
            BorderBrush="{DynamicResource QuickBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26"
                              ShadowDepth="2"
                              Opacity="0.24" />
        </Border.Effect>
        <DockPanel>
            <Grid x:Name="HeaderBar"
                  DockPanel.Dock="Top"
                  Margin="4,1,4,8"
                  Cursor="SizeAll"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TitleText"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource QuickTextBrush}" />
                <TextBlock x:Name="KeyboardHelpText"
                           Grid.Column="1"
                           FontSize="11"
                           Foreground="{DynamicResource QuickSecondaryTextBrush}"
                           Text="" />
            </Grid>

            <ListBox x:Name="ItemsList"
                     MinHeight="80"
                     MaxHeight="480"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     KeyboardNavigation.TabNavigation="Cycle"
                     KeyDown="ItemsList_OnKeyDown"
                     PreviewMouseLeftButtonUp="ItemsList_OnPreviewMouseLeftButtonUp">
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,2" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="Row"
                                Padding="9,8"
                                CornerRadius="7"
                                Background="{DynamicResource QuickItemBrush}"
                                BorderBrush="{DynamicResource QuickItemBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="IconColumn" Width="52" />
                                    <ColumnDefinition Width="*" MinWidth="0" />
                                    <ColumnDefinition Width="86" />
                                </Grid.ColumnDefinitions>
                                <Border Width="34"
                                        Height="26"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource QuickFolderBrush}"
                                        BorderBrush="{DynamicResource QuickFolderBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Visibility="{Binding FolderIconVisibility}">
                                    <Viewbox Width="18"
                                             Height="18"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Path Data="M10 4H2C0.9 4 0 4.9 0 6V18C0 19.1 0.9 20 2 20H22C23.1 20 24 19.1 24 18V8C24 6.9 23.1 6 22 6H12L10 4Z"
                                              Fill="{DynamicResource QuickFolderTextBrush}"
                                              Stretch="Uniform" />
                                    </Viewbox>
                                </Border>
                                <Border Width="22"
                                        Height="22"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="{Binding AccentBrush}"
                                        CornerRadius="3"
                                        Visibility="{Binding IconVisibility}">
                                    <TextBlock Text="{Binding KindLabel}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="White" />
                                </Border>
                                <Border Width="44"
                                        Height="32"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource QuickPreviewBrush}"
                                        BorderBrush="{DynamicResource QuickPreviewBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Visibility="{Binding PreviewVisibility}">
                                    <Image Source="{Binding PreviewImage}"
                                           Stretch="Uniform" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="12.5"
                                               Foreground="{DynamicResource QuickTextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="Wrap"
                                               MaxHeight="36" />
                                    <TextBlock Text="{Binding Subtitle}"
                                               Margin="0,1,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource QuickSecondaryTextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource QuickSecondaryTextBrush}"
                                           Text="{Binding CommandHint}"
                                           Visibility="{Binding CommandHintVisibility}" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource QuickFolderTextBrush}"
                                           Text=">"
                                           Visibility="{Binding FolderChevronVisibility}" />
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="{DynamicResource QuickFolderRowBrush}" />
                                <Setter TargetName="Row" Property="BorderBrush" Value="{DynamicResource QuickFolderBorderBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="{DynamicResource QuickSelectionBrush}" />
                                <Setter TargetName="Row" Property="BorderBrush" Value="{DynamicResource QuickFocusBorderBrush}" />
                                <Setter TargetName="Row" Property="BorderThickness" Value="1" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                <Setter TargetName="Row" Property="BorderBrush" Value="{DynamicResource QuickFocusBorderBrush}" />
                                <Setter TargetName="Row" Property="BorderThickness" Value="1" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSimpleMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <Setter TargetName="Row" Property="Padding" Value="12,7" />
                                <Setter TargetName="Row" Property="CornerRadius" Value="4" />
                                <Setter TargetName="IconColumn" Property="Width" Value="28" />
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSimpleMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                    <Condition Binding="{Binding IsFolder}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="IconColumn" Property="Width" Value="0" />
                            </MultiDataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
