<Window x:Class="Clipton.App.QuickMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="390"
        SizeToContent="Height"
        MaxHeight="560"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="True"
        Topmost="True"
        Background="Transparent"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        Deactivated="Window_OnDeactivated">
    <Window.Resources>
        <SolidColorBrush x:Key="QuickPanelBrush" Color="#F9FAFB" />
        <SolidColorBrush x:Key="QuickBorderBrush" Color="#9AA5B1" />
        <SolidColorBrush x:Key="QuickTextBrush" Color="#111827" />
        <SolidColorBrush x:Key="QuickSecondaryTextBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="QuickSelectionBrush" Color="#DDEBFA" />
        <SolidColorBrush x:Key="QuickPreviewBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="QuickPreviewBorderBrush" Color="#CAD3DD" />
    </Window.Resources>
    <Border Background="{DynamicResource QuickPanelBrush}"
            BorderBrush="{DynamicResource QuickBorderBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="2"
                              Opacity="0.22" />
        </Border.Effect>
        <DockPanel>
            <Grid DockPanel.Dock="Top"
                  Margin="6,3,6,6"
                  Cursor="SizeAll"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TitleText"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource QuickTextBrush}" />
                <TextBlock Grid.Column="1"
                           FontSize="11"
                           Foreground="{DynamicResource QuickSecondaryTextBrush}"
                           Text="Enter: Paste  T: Text  Esc" />
            </Grid>

            <ListBox x:Name="ItemsList"
                     MinHeight="80"
                     MaxHeight="480"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     KeyboardNavigation.TabNavigation="Cycle"
                     KeyDown="ItemsList_OnKeyDown"
                     PreviewMouseLeftButtonUp="ItemsList_OnPreviewMouseLeftButtonUp">
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,1" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource QuickSelectionBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8,5" CornerRadius="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52" />
                                    <ColumnDefinition Width="*" MinWidth="0" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="22"
                                        Height="22"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="{Binding AccentBrush}"
                                        CornerRadius="3"
                                        Visibility="{Binding IconVisibility}">
                                    <TextBlock Text="{Binding KindLabel}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="White" />
                                </Border>
                                <Border Width="44"
                                        Height="32"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource QuickPreviewBrush}"
                                        BorderBrush="{DynamicResource QuickPreviewBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Visibility="{Binding PreviewVisibility}">
                                    <Image Source="{Binding PreviewImage}"
                                           Stretch="Uniform" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="12"
                                               Foreground="{DynamicResource QuickTextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="Wrap"
                                               MaxHeight="34" />
                                    <TextBlock Text="{Binding Subtitle}"
                                               Margin="0,1,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource QuickSecondaryTextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource QuickSecondaryTextBrush}"
                                           Text="{Binding CommandHint}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
