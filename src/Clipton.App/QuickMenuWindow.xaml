<Window x:Class="Clipton.App.QuickMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420"
        SizeToContent="Height"
        MaxHeight="560"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="True"
        Topmost="True"
        Background="Transparent"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        Deactivated="Window_OnDeactivated">
    <Border Background="#FAFAFA"
            BorderBrush="#B8C2CC"
            BorderThickness="1"
            CornerRadius="6"
            Padding="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="2"
                              Opacity="0.22" />
        </Border.Effect>
        <DockPanel>
            <Grid DockPanel.Dock="Top" Margin="4,2,4,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TitleText"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#1F2933" />
                <TextBlock Grid.Column="1"
                           FontSize="11"
                           Foreground="#6B7280"
                           Text="Enter / Esc" />
            </Grid>

            <ListBox x:Name="ItemsList"
                     MinHeight="80"
                     MaxHeight="480"
                     BorderThickness="0"
                     Background="Transparent"
                     KeyboardNavigation.TabNavigation="Cycle"
                     KeyDown="ItemsList_OnKeyDown"
                     MouseDoubleClick="ItemsList_OnMouseDoubleClick">
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,1" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E6F0FA" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10,7" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="4"
                                        Margin="0,2,10,2"
                                        Background="{Binding AccentBrush}"
                                        CornerRadius="2" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="13"
                                               Foreground="#111827"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Subtitle}"
                                               Margin="0,2,0,0"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
